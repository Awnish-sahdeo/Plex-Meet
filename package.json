{
  "name": "webrtc-meeting-platform",
  "version": "1.0.0",
  "private": true,
  "description": "WebRTC Meeting Platform Monorepo",
  "workspaces": [
    "client",
    "signaling-server"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=signaling-server",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
